# To create or update a token visit https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"

# RPC URLs for external view calls (Aave adapter detection + order removal polling)
# Used by src/effects/rpc.ts — not needed for basic event indexing (HyperSync handles that)
ENVIO_RPC_URL_1=<YOUR-ETHEREUM-RPC-URL>
ENVIO_RPC_URL_100=<YOUR-GNOSIS-RPC-URL>
ENVIO_RPC_URL_42161=<YOUR-ARBITRUM-RPC-URL>
ENVIO_RPC_URL_8453=<YOUR-BASE-RPC-URL>
ENVIO_RPC_URL_11155111=<YOUR-SEPOLIA-RPC-URL>